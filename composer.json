{
    "name": "brynj-digital/laravel-model-vectorize",
    "version": "2.0.1",
    "description": "Standalone Laravel package for Cloudflare Vectorize semantic search",
    "keywords": [
        "laravel",
        "vectorize",
        "cloudflare",
        "semantic-search",
        "vector-search",
        "embeddings",
        "ai"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Bryn Jones",
            "email": "bryn@lunarvis.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "BrynjDigital\\LaravelModelVectorize\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BrynjDigital\\LaravelModelVectorize\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BrynjDigital\\LaravelModelVectorize\\VectorizeServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
